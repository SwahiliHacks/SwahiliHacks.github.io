---
// index.astro — the homepage.
//
// Purpose: Renders a professional problem-solution homepage with a clean,
// modern design. No emojis, no childish elements.

import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ToolCard from '../components/ToolCard.astro';

const categories = await getCollection('categories');

// Preserve the original homepage ordering
const ORDER = [
  'trading', 'productivity', 'online-income',
  'trading-automation', 'learning-courses', 'affiliate-platforms',
  'ai-tools', 'content-creation', 'ecommerce',
  'finance-management', 'remote-work', 'digital-services',
];
const orderedCategories = ORDER
  .map((slug) => categories.find((c) => c.id === slug))
  .filter((c): c is NonNullable<typeof c> => Boolean(c));
---

<BaseLayout
  title="Swahili Hacks - Professional Solutions & Resources"
  description="Curated solutions for trading, productivity, online income, and business growth — engineered for professionals."
  path="/"
>
  <!-- Header with professional trust tag -->
  <Header
    trustTag="Curated solutions for professional results"
    stats={[
      { number: '500+', label: 'Problems Solved' },
      { number: '12', label: 'Categories' },
      { number: '24/7', label: 'Access' },
    ]}
  />

  <main>
    <!-- Hero Section - Problem Statement -->
    <section class="hero-section">
      <div class="hero-container">
        <div class="hero-content">
          <div class="hero-badge">Solutions for Digital Problems</div>
          <h1 class="hero-title">
            <span style="color: #ffffff;">Find the </span>
            <span class="highlight-wrapper">
              <span class="highlight">Solution</span>
            </span>
            <span style="color: #ffffff;"> to Your Professional Challenge</span>
          </h1>
          <p class="hero-description">
            Curated solutions for trading, productivity, online income, e-commerce, 
            and business growth. Every tool tested and verified by an engineer.
          </p>
          <div class="hero-actions">
            <a href="#categories" class="btn-primary">Explore Solutions</a>
            <a href="/about/" class="btn-secondary">About</a>
          </div>
        </div>
        <div class="hero-stats">
          <div class="stat-item">
            <span class="stat-number">500+</span>
            <span class="stat-label">Problems Solved</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">12</span>
            <span class="stat-label">Categories</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">95%</span>
            <span class="stat-label">Success Rate</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Categories Section -->
    <section class="categories-section" id="categories">
      <div class="container">
        <div class="section-header">
          <h2>Professional Solutions by Category</h2>
          <p class="section-subtitle">Choose your area of focus and find the right tools.</p>
        </div>

        <div class="tools-grid">
          {
            orderedCategories.map((category) => (
              <ToolCard
                slug={category.id}
                icon={category.data.icon}
                title={category.data.nav_label}
                teaser={category.data.card_teaser}
                bullets={category.data.card_bullets}
                bgImage={category.data.card_bg_image}
                ctaText={category.data.card_cta_text}
              />
            ))
          }
        </div>
      </div>
    </section>

    <!-- Trust Section - No emojis -->
    <section class="trust-section">
      <div class="container">
        <div class="section-header">
          <h2>Trusted by Professionals Worldwide</h2>
          <p class="section-subtitle">Real results from real professionals.</p>
        </div>
        <div class="trust-grid">
          <div class="trust-card">
            <div class="trust-number">50,000+</div>
            <div class="trust-label">Monthly Visitors</div>
            <div class="trust-desc">Finding professional solutions</div>
          </div>
          <div class="trust-card">
            <div class="trust-number">95%</div>
            <div class="trust-label">Success Rate</div>
            <div class="trust-desc">Users found what they needed</div>
          </div>
          <div class="trust-card">
            <div class="trust-number">12</div>
            <div class="trust-label">Categories</div>
            <div class="trust-desc">500+ problems covered</div>
          </div>
          <div class="trust-card">
            <div class="trust-number">24/7</div>
            <div class="trust-label">Access</div>
            <div class="trust-desc">Solutions always available</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Newsletter Section - Clean -->
    <section class="newsletter-section">
      <div class="container newsletter-container">
        <div class="newsletter-content">
          <h2>Get Professional Insights</h2>
          <p>Subscribe for weekly problem-solution guides and curated tools.</p>
          <form class="newsletter-form">
            <input type="email" placeholder="Enter your email address" aria-label="Email address" />
            <button type="submit" class="btn-subscribe">Subscribe</button>
          </form>
          <p class="form-note">No spam. Unsubscribe anytime. Privacy respected.</p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* ===== HERO SECTION ===== */
  .hero-section {
    padding: 4rem 2rem;
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    color: white;
    min-height: 60vh;
    display: flex;
    align-items: center;
  }
  
  .hero-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 4rem;
    align-items: center;
    width: 100%;
  }
  
  .hero-content {
    max-width: 600px;
  }
  
  .hero-badge {
    display: inline-block;
    padding: 0.4rem 1rem;
    background: rgba(28, 117, 188, 0.15);
    color: #60a5fa;
    border-radius: 4px;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.5px;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(28, 117, 188, 0.2);
  }
  
  .hero-title {
    font-size: 3.2rem;
    font-weight: 800;
    line-height: 1.5;
    margin-bottom: 1.5rem;
  }
  
  .highlight-wrapper {
    display: inline-block;
    position: relative;
  }
  
  .highlight {
    color: #60a5fa;
  }
  
  .highlight-wrapper::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 0;
    width: 100%;
    height: 3px;
    background: #1C75BC;
    border-radius: 2px;
  }
  
  .hero-description {
    font-size: 1.15rem;
    color: #94a3b8;
    line-height: 1.8;
    margin-bottom: 2rem;
  }
  
  .hero-stats {
    display: flex;
    gap: 3rem;
  }
  
  .stat-item {
    text-align: center;
  }
  
  .stat-number {
    display: block;
    font-size: 2rem;
    font-weight: 700;
    color: #60a5fa;
  }
  
  .stat-label {
    font-size: 0.8rem;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  
  .hero-actions {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  
  .btn-primary {
    background: #1C75BC;
    color: white;
    padding: 0.8rem 2rem;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    border: none;
  }
  
  .btn-primary:hover {
    background: #145a8a;
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(28, 117, 188, 0.3);
  }
  
  .btn-secondary {
    background: transparent;
    color: white;
    padding: 0.8rem 2rem;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 500;
    border: 1px solid rgba(255, 255, 255, 0.2);
    transition: all 0.3s ease;
  }
  
  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.4);
  }
  
  /* ===== CATEGORIES SECTION ===== */
  .categories-section {
    padding: 4rem 2rem;
    background: #f8fafc;
  }
  
  .container {
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .section-header h2 {
    font-size: 2.2rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 0.5rem;
  }
  
  .section-subtitle {
    color: #64748b;
    font-size: 1.05rem;
  }
  
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }
  
  /* ===== TRUST SECTION ===== */
  .trust-section {
    padding: 4rem 2rem;
    background: white;
  }
  
  .trust-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    max-width: 1000px;
    margin: 0 auto;
  }
  
  .trust-card {
    text-align: center;
    padding: 2rem;
    background: #f8fafc;
    border-radius: 8px;
    border: 1px solid #e2e8f0;
    transition: all 0.3s ease;
  }
  
  .trust-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    border-color: #1C75BC;
  }
  
  .trust-number {
    font-size: 2.5rem;
    font-weight: 800;
    color: #1C75BC;
    font-family: 'Poppins', sans-serif;
  }
  
  .trust-label {
    font-size: 1rem;
    font-weight: 600;
    color: #0f172a;
    margin-top: 0.5rem;
  }
  
  .trust-desc {
    font-size: 0.85rem;
    color: #64748b;
    margin-top: 0.25rem;
  }
  
  /* ===== NEWSLETTER SECTION ===== */
  .newsletter-section {
    padding: 4rem 2rem;
    background: #f8fafc;
  }
  
  .newsletter-container {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }
  
  .newsletter-content h2 {
    font-size: 1.8rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 0.5rem;
  }
  
  .newsletter-content p {
    color: #64748b;
    font-size: 1rem;
    margin-bottom: 1.5rem;
  }
  
  .newsletter-form {
    display: flex;
    gap: 0.5rem;
    max-width: 500px;
    margin: 0 auto;
  }
  
  .newsletter-form input {
    flex: 1;
    padding: 0.8rem 1rem;
    border: 2px solid #e2e8f0;
    border-radius: 6px;
    font-size: 1rem;
    outline: none;
    transition: all 0.3s ease;
  }
  
  .newsletter-form input:focus {
    border-color: #1C75BC;
    box-shadow: 0 0 0 3px rgba(28, 117, 188, 0.1);
  }
  
  .btn-subscribe {
    background: #1C75BC;
    color: white;
    padding: 0.8rem 2rem;
    border: none;
    border-radius: 6px;
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
  }
  
  .btn-subscribe:hover {
    background: #145a8a;
  }
  
  .form-note {
    font-size: 0.8rem;
    color: #94a3b8;
    margin-top: 0.75rem;
  }
  
  /* ===== RESPONSIVE DESIGN ===== */
  @media (max-width: 1024px) {
    .hero-container {
      grid-template-columns: 1fr;
      text-align: center;
    }
    
    .hero-content {
      max-width: 100%;
    }
    
    .hero-title {
      font-size: 2.8rem;
    }
    
    .hero-stats {
      justify-content: center;
    }
    
    .hero-actions {
      justify-content: center;
    }
    
    .trust-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (max-width: 768px) {
    .hero-title {
      font-size: 2.2rem;
      line-height: 1.4;
    }
    
    .hero-description {
      font-size: 1rem;
    }
    
    .hero-stats {
      gap: 1.5rem;
    }
    
    .stat-number {
      font-size: 1.6rem;
    }
    
    .tools-grid {
      grid-template-columns: 1fr;
    }
    
    .trust-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
    
    .trust-card {
      padding: 1.5rem;
    }
    
    .trust-number {
      font-size: 2rem;
    }
    
    .highlight-wrapper::after {
      bottom: 2px;
    }
    
    .newsletter-form {
      flex-direction: column;
    }
    
    .btn-subscribe {
      width: 100%;
    }
  }
  
  @media (max-width: 480px) {
    .hero-title {
      font-size: 1.6rem;
      line-height: 1.3;
    }
    
    .hero-stats {
      flex-direction: column;
      gap: 0.5rem;
    }
    
    .trust-grid {
      grid-template-columns: 1fr;
    }
    
    .section-header h2 {
      font-size: 1.6rem;
    }
    
    .highlight-wrapper::after {
      bottom: 1px;
      height: 2px;
    }
  }
</style>
