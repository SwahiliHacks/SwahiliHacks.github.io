---
// index.astro — the homepage.
//
// Purpose: Renders a professional problem-solution homepage with a clean,
// modern design. No emojis, no childish elements.

import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ToolCard from '../components/ToolCard.astro';
import SearchBar from '../components/SearchBar.astro';

const categories = await getCollection('categories');

// Preserve the original homepage ordering
const ORDER = [
  'wealth-investment',
  'productivity-workflow-systems',
  'online-income-opportunities',
  'automated-wealth-systems',
  'career-growth-skills-development',
  'digital-income-monetization',
  'ai-intelligent-automation',
  'content-creation-digital-media',
  'ecommerce-online-business',
  'personal-finance-money-management',
  'remote-work-distributed-teams',
  'freelancing-professional-services',
];

const orderedCategories = ORDER
  .map((slug) => categories.find((c) => c.id === slug))
  .filter((c): c is NonNullable<typeof c> => Boolean(c));

// ============================================================
// SHOP CATEGORIES DATA
// ============================================================
const shopCategories = [
  {
    slug: 'electronics',
    name: 'Electronics & Gadgets',
    icon: 'fa-solid fa-laptop',
    description: 'Smartphones, laptops, accessories, audio',
    productCount: 25,
    color: '#3b82f6'
  },
  {
    slug: 'home-kitchen',
    name: 'Home & Kitchen',
    icon: 'fa-solid fa-house',
    description: 'Appliances, cookware, furniture',
    productCount: 18,
    color: '#f59e0b'
  },
  {
    slug: 'solar-energy',
    name: 'Solar & Energy',
    icon: 'fa-solid fa-sun',
    description: 'Solar panels, batteries, inverters, lights',
    productCount: 15,
    color: '#22c55e'
  },
  {
    slug: 'agriculture',
    name: 'Agriculture',
    icon: 'fa-solid fa-seedling',
    description: 'Water pumps, irrigation, tools, seeds',
    productCount: 12,
    color: '#84cc16'
  },
  {
    slug: 'fashion-wear',
    name: 'Fashion & Wear',
    icon: 'fa-solid fa-tshirt',
    description: 'Clothing, shoes, accessories, watches',
    productCount: 20,
    color: '#ec4899'
  },
  {
    slug: 'health-fitness',
    name: 'Health & Fitness',
    icon: 'fa-solid fa-heart-pulse',
    description: 'Gym equipment, supplements, health monitors',
    productCount: 10,
    color: '#ef4444'
  },
  {
    slug: 'beauty-care',
    name: 'Beauty & Personal Care',
    icon: 'fa-solid fa-spa',
    description: 'Skincare, makeup, hair care, grooming',
    productCount: 14,
    color: '#f472b6'
  },
  {
    slug: 'automotive',
    name: 'Automotive & Motorcycle',
    icon: 'fa-solid fa-car',
    description: 'Car accessories, helmets, gear, parts',
    productCount: 11,
    color: '#64748b'
  },
  {
    slug: 'office-stationery',
    name: 'Office & Stationery',
    icon: 'fa-solid fa-pen-ruler',
    description: 'Chairs, desks, stationery, printers',
    productCount: 8,
    color: '#8b5cf6'
  }
];

// ============================================================
// DIGITAL CATEGORIES DATA
// ============================================================
const digitalCategories = [
  {
    slug: 'hosting-domains',
    name: 'Web Hosting & Domains',
    icon: 'fa-solid fa-globe',
    description: 'Bluehost, Hostinger, Namecheap, WordPress',
    productCount: 8,
    color: '#3b82f6',
    commission: 'High'
  },
  {
    slug: 'vpn-security',
    name: 'VPN & Cybersecurity',
    icon: 'fa-solid fa-shield-halved',
    description: 'NordVPN, ExpressVPN, Antivirus, Password managers',
    productCount: 6,
    color: '#22c55e',
    commission: 'High'
  },
  {
    slug: 'ai-tools',
    name: 'AI Tools',
    icon: 'fa-solid fa-brain',
    description: 'ChatGPT Plus, Jasper, Midjourney, Synthesia',
    productCount: 7,
    color: '#8b5cf6',
    commission: 'Recurring'
  },
  {
    slug: 'trading-platforms',
    name: 'Trading Platforms',
    icon: 'fa-solid fa-chart-line',
    description: 'TradingView, MT4, Binance, Exness, Bybit',
    productCount: 8,
    color: '#f59e0b',
    commission: 'High'
  },
  {
    slug: 'online-courses',
    name: 'Online Courses',
    icon: 'fa-solid fa-graduation-cap',
    description: 'Coursera, Udemy, Codecademy, LinkedIn Learning',
    productCount: 6,
    color: '#ec4899',
    commission: 'High'
  },
  {
    slug: 'marketing-tools',
    name: 'Marketing & Productivity',
    icon: 'fa-solid fa-rocket',
    description: 'Canva, Notion, Slack, Mailchimp, Zapier',
    productCount: 10,
    color: '#06b6d4',
    commission: 'Recurring'
  }
];
---

<BaseLayout
  title="Swahili Hacks - Professional Solutions & Resources"
  description="Curated solutions for trading, productivity, online income, and business growth — engineered for professionals."
  path="/"
>
  <!-- Header with professional trust tag -->
  <Header
    trustTag="Curated solutions for professional results"
    stats={[
      { number: '500+', label: 'Problems Solved' },
      { number: '12', label: 'Categories' },
      { number: '24/7', label: 'Access' },
    ]}
  />

  <main>
    <!-- Hero Section - Problem Statement -->
    <section class="hero-section">
      <div class="hero-container">
        <div class="hero-content">
          <div class="hero-badge">Solutions for Digital Problems</div>
          <h1 class="hero-title">
            <span style="color: #ffffff;">Find the </span>
            <span class="highlight-wrapper">
              <span class="highlight">Solution</span>
            </span>
            <span style="color: #ffffff;"> to Your Professional Challenge</span>
          </h1>
          <p class="hero-description">
            Curated solutions for trading, productivity, online income, e-commerce, 
            and business growth. Every tool tested and verified by an engineer.
          </p>
          <div class="hero-actions">
            <a href="#categories" class="btn-primary">Explore Solutions</a>
          </div>
        </div>
        <div class="hero-stats">
          <div class="stat-item">
            <span class="stat-number">500+</span>
            <span class="stat-label">Problems Solved</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">12</span>
            <span class="stat-label">Categories</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">95%</span>
            <span class="stat-label">Success Rate</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Search Section -->
    <section class="search-section">
      <div class="container">
        <SearchBar categories={categories} />
      </div>
    </section>

    <!-- Solutions Categories Section -->
    <section class="categories-section" id="categories">
      <div class="container">
        <div class="section-header">
          <h2>Professional Solutions by Category</h2>
          <p class="section-subtitle">Choose your area of focus and find the right tools.</p>
        </div>

        <div class="tools-grid">
          {
            orderedCategories.map((category) => (
              <ToolCard
                slug={category.id}
                icon={category.data.icon}
                title={category.data.nav_label}
                teaser={category.data.card_teaser}
                bullets={category.data.card_bullets}
                bgImage={category.data.card_bg_image}
                ctaText={category.data.card_cta_text}
              />
            ))
          }
        </div>
      </div>
    </section>

    <!-- Shop Section - Preview -->
    <section class="shop-preview">
      <div class="container">
        <div class="section-header">
          <h2>Shop Products</h2>
          <p>Find electronics, solar, agriculture, and more.</p>
          <a href="/shop/" class="view-all">View All →</a>
        </div>
        <div class="shop-grid">
          {shopCategories.slice(0, 4).map((cat) => (
            <a href={`/shop/${cat.slug}/`} class="shop-card" style={`--card-color: ${cat.color}`}>
              <div class="shop-icon">
                <i class={cat.icon}></i>
              </div>
              <h3>{cat.name}</h3>
              <span class="shop-count">{cat.productCount} Products</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Digital Section - Preview -->
    <section class="digital-preview">
      <div class="container">
        <div class="section-header">
          <h2>Digital Products</h2>
          <p>Hosting, VPN, AI tools, trading platforms, and more.</p>
          <a href="/digital/" class="view-all">View All →</a>
        </div>
        <div class="digital-grid">
          {digitalCategories.slice(0, 4).map((cat) => (
            <a href={`/digital/${cat.slug}/`} class="digital-card" style={`--card-color: ${cat.color}`}>
              <div class="digital-icon">
                <i class={cat.icon}></i>
              </div>
              <h3>{cat.name}</h3>
              <span class="digital-count">{cat.productCount} Products</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Trust Section -->
    <section class="trust-section">
      <div class="container">
        <div class="section-header">
          <h2>Trusted by Professionals Worldwide</h2>
          <p class="section-subtitle">Real results from real professionals.</p>
        </div>
        <div class="trust-grid">
          <div class="trust-card">
            <div class="trust-number">50,000+</div>
            <div class="trust-label">Monthly Visitors</div>
            <div class="trust-desc">Finding professional solutions</div>
          </div>
          <div class="trust-card">
            <div class="trust-number">95%</div>
            <div class="trust-label">Success Rate</div>
            <div class="trust-desc">Users found what they needed</div>
          </div>
          <div class="trust-card">
            <div class="trust-number">12</div>
            <div class="trust-label">Categories</div>
            <div class="trust-desc">500+ problems covered</div>
          </div>
          <div class="trust-card">
            <div class="trust-number">24/7</div>
            <div class="trust-label">Access</div>
            <div class="trust-desc">Solutions always available</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Newsletter Section -->
    <section class="newsletter-section">
      <div class="container newsletter-container">
        <div class="newsletter-content">
          <h2>Get Professional Insights</h2>
          <p>Subscribe for weekly problem-solution guides and curated tools.</p>
          <form class="newsletter-form">
            <input type="email" placeholder="Enter your email address" aria-label="Email address" />
            <button type="submit" class="btn-subscribe">Subscribe</button>
          </form>
          <p class="form-note">No spam. Unsubscribe anytime. Privacy respected.</p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* ===== HERO SECTION ===== */
  .hero-section {
    padding: 4rem 2rem;
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    color: white;
    min-height: 60vh;
    display: flex;
    align-items: center;
  }
  
  .hero-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 4rem;
    align-items: center;
    width: 100%;
  }
  
  .hero-content {
    max-width: 600px;
  }
  
  .hero-badge {
    display: inline-block;
    padding: 0.4rem 1rem;
    background: rgba(28, 117, 188, 0.15);
    color: #60a5fa;
    border-radius: 4px;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.5px;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(28, 117, 188, 0.2);
  }
  
  .hero-title {
    font-size: 3.2rem;
    font-weight: 800;
    line-height: 1.5;
    margin-bottom: 1.5rem;
  }
  
  .highlight-wrapper {
    display: inline-block;
    position: relative;
  }
  
  .highlight {
    color: #60a5fa;
  }
  
  .highlight-wrapper::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 0;
    width: 100%;
    height: 3px;
    background: #1C75BC;
    border-radius: 2px;
  }
  
  .hero-description {
    font-size: 1.15rem;
    color: #94a3b8;
    line-height: 1.8;
    margin-bottom: 2rem;
  }
  
  .hero-stats {
    display: flex;
    gap: 3rem;
  }
  
  .stat-item {
    text-align: center;
  }
  
  .stat-number {
    display: block;
    font-size: 2rem;
    font-weight: 700;
    color: #60a5fa;
  }
  
  .stat-label {
    font-size: 0.8rem;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  
  .hero-actions {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  
  .btn-primary {
    background: #1C75BC;
    color: white;
    padding: 0.8rem 2rem;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    border: none;
  }
  
  .btn-primary:hover {
    background: #145a8a;
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(28, 117, 188, 0.3);
  }
  
  /* ===== SEARCH SECTION ===== */
  .search-section {
    padding: 2rem 0;
    background: #f8fafc;
  }

  .search-section .container {
    max-width: 1200px;
    margin: 0 auto;
  }
  
  /* ===== CATEGORIES SECTION ===== */
  .categories-section {
    padding: 4rem 2rem;
    background: #f8fafc;
  }
  
  .container {
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .section-header h2 {
    font-size: 2.2rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 0.5rem;
  }
  
  .section-subtitle {
    color: #64748b;
    font-size: 1.05rem;
  }
  
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }
  
  /* ===== SHOP PREVIEW ===== */
  .shop-preview {
    padding: 4rem 2rem;
    background: white;
  }

  .shop-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .shop-card {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 1.5rem;
    text-decoration: none;
    color: #0f172a;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .shop-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.06);
    border-color: var(--card-color, #1C75BC);
  }

  .shop-icon {
    font-size: 2rem;
    color: var(--card-color, #1C75BC);
    margin-bottom: 0.5rem;
  }

  .shop-icon i {
    font-size: 2rem;
  }

  .shop-card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .shop-count {
    font-size: 0.8rem;
    color: #94a3b8;
  }

  .view-all {
    display: inline-block;
    margin-top: 0.5rem;
    color: #1C75BC;
    font-weight: 600;
    text-decoration: none;
  }

  .view-all:hover {
    text-decoration: underline;
  }

  /* ===== DIGITAL PREVIEW ===== */
  .digital-preview {
    padding: 4rem 2rem;
    background: #f8fafc;
  }

  .digital-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .digital-card {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 1.5rem;
    text-decoration: none;
    color: #0f172a;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .digital-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.06);
    border-color: var(--card-color, #1C75BC);
  }

  .digital-icon {
    font-size: 2rem;
    color: var(--card-color, #1C75BC);
    margin-bottom: 0.5rem;
  }

  .digital-icon i {
    font-size: 2rem;
  }

  .digital-card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .digital-count {
    font-size: 0.8rem;
    color: #94a3b8;
  }

  /* ===== TRUST SECTION ===== */
  .trust-section {
    padding: 4rem 2rem;
    background: white;
  }
  
  .trust-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    max-width: 1000px;
    margin: 0 auto;
  }
  
  .trust-card {
    text-align: center;
    padding: 2rem;
    background: #f8fafc;
    border-radius: 8px;
    border: 1px solid #e2e8f0;
    transition: all 0.3s ease;
  }
  
  .trust-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    border-color: #1C75BC;
  }
  
  .trust-number {
    font-size: 2.5rem;
    font-weight: 800;
    color: #1C75BC;
    font-family: 'Poppins', sans-serif;
  }
  
  .trust-label {
    font-size: 1rem;
    font-weight: 600;
    color: #0f172a;
    margin-top: 0.5rem;
  }
  
  .trust-desc {
    font-size: 0.85rem;
    color: #64748b;
    margin-top: 0.25rem;
  }
  
  /* ===== NEWSLETTER SECTION ===== */
  .newsletter-section {
    padding: 4rem 2rem;
    background: #f8fafc;
  }
  
  .newsletter-container {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }
  
  .newsletter-content h2 {
    font-size: 1.8rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 0.5rem;
  }
  
  .newsletter-content p {
    color: #64748b;
    font-size: 1rem;
    margin-bottom: 1.5rem;
  }
  
  .newsletter-form {
    display: flex;
    gap: 0.5rem;
    max-width: 500px;
    margin: 0 auto;
  }
  
  .newsletter-form input {
    flex: 1;
    padding: 0.8rem 1rem;
    border: 2px solid #e2e8f0;
    border-radius: 6px;
    font-size: 1rem;
    outline: none;
    transition: all 0.3s ease;
  }
  
  .newsletter-form input:focus {
    border-color: #1C75BC;
    box-shadow: 0 0 0 3px rgba(28, 117, 188, 0.1);
  }
  
  .btn-subscribe {
    background: #1C75BC;
    color: white;
    padding: 0.8rem 2rem;
    border: none;
    border-radius: 6px;
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
  }
  
  .btn-subscribe:hover {
    background: #145a8a;
  }
  
  .form-note {
    font-size: 0.8rem;
    color: #94a3b8;
    margin-top: 0.75rem;
  }
  
  /* ===== RESPONSIVE DESIGN ===== */
  @media (max-width: 1024px) {
    .hero-container {
      grid-template-columns: 1fr;
      text-align: center;
    }
    
    .hero-content {
      max-width: 100%;
    }
    
    .hero-title {
      font-size: 2.8rem;
    }
    
    .hero-stats {
      justify-content: center;
    }
    
    .hero-actions {
      justify-content: center;
    }
    
    .trust-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .shop-grid,
    .digital-grid {
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    }
  }
  
  @media (max-width: 768px) {
    .hero-title {
      font-size: 2.2rem;
      line-height: 1.4;
    }
    
    .hero-description {
      font-size: 1rem;
    }
    
    .hero-stats {
      gap: 1.5rem;
    }
    
    .stat-number {
      font-size: 1.6rem;
    }
    
    .tools-grid {
      grid-template-columns: 1fr;
    }
    
    .trust-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
    
    .trust-card {
      padding: 1.5rem;
    }
    
    .trust-number {
      font-size: 2rem;
    }
    
    .highlight-wrapper::after {
      bottom: 2px;
    }
    
    .newsletter-form {
      flex-direction: column;
    }
    
    .btn-subscribe {
      width: 100%;
    }

    .shop-grid,
    .digital-grid {
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    }
  }
  
  @media (max-width: 480px) {
    .hero-title {
      font-size: 1.6rem;
      line-height: 1.3;
    }
    
    .hero-stats {
      flex-direction: column;
      gap: 0.5rem;
    }
    
    .trust-grid {
      grid-template-columns: 1fr;
    }
    
    .section-header h2 {
      font-size: 1.6rem;
    }
    
    .highlight-wrapper::after {
      bottom: 1px;
      height: 2px;
    }

    .shop-grid,
    .digital-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
