    'solar-energy',
    'agriculture',
    'fashion-wear',
    'health-fitness',
    'beauty-care',
    'automotive',
    'office-stationery'
  ];
  
  return categories.map((category) => ({
    params: { category },
    props: { category }
  }));
}

