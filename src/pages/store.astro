// ============================================================
// 📊 Category Data for Filtering
// ============================================================

const categories = ['All Categories', ...new Set(products.map(p => p.category))];
const featuredProducts = products.filter(p => p.featured);

// Helper function to render stars
function renderStars(rating: number) {
  const fullStars = Math.floor(rating);
  const halfStar = rating % 1 >= 0.5 ? 1 : 0;
  const emptyStars = 5 - fullStars - halfStar;
  let stars = '';
  for (let i = 0; i < fullStars; i++) stars += '⭐';
  if (halfStar) stars += '⭐';
  for (let i = 0; i < emptyStars; i++) stars += '☆';
  return stars;
}
---

<BaseLayout
  title="Online Store - Swahili Hacks"
  description="Curated products from trusted sources. Find the best tools for trading, productivity, AI, and online business."
  path="/store/"
>
  <!-- Hero Section -->
  <section class="store-hero">
    <div class="container">
      <h1>🛍️ Swahili Hacks Online Store</h1>
      <p>Curated products from trusted sources. Every product is tested and verified.</p>
    </div>
  </section>

  <!-- Category Filter -->
  <section class="filter-section">
    <div class="container">
      <div class="filter-bar">
        <label for="category-filter">Filter by Category:</label>
        <select id="category-filter" class="filter-select">
          {categories.map(cat => (
            <option value={cat === 'All Categories' ? 'all' : cat}>
              {cat}
            </option>
          ))}
        </select>
        <span class="product-count" id="product-count">{products.length} Products</span>
      </div>
    </div>
  </section>

  <!-- Featured Products -->
  {featuredProducts.length > 0 && (
    <section class="store-section featured-section">
      <div class="container">
        <h2>⭐ Featured Products</h2>
        <div class="product-grid featured-grid">
          {featuredProducts.map(product => (
            <div class="product-card featured" data-category={product.category}>
              {product.badge && (
                <div class="product-badge">{product.badge}</div>
              )}
              <div class="product-image">
                <img 
                  src={product.image} 
                  alt={product.name}
                  loading="lazy"
                  onerror="this.src='/images/store/default-product.jpg'"
                />
              </div>
              <div class="product-content">
                <span class="product-category">{product.category}</span>
                <h3>{product.name}</h3>
                <p>{product.description}</p>
                <div class="product-meta">
                  <span class="product-rating">
                    {renderStars(product.rating)} {product.rating}
                  </span>
                  <span class="product-reviews">({product.reviews} reviews)</span>
                </div>
                <div class="product-footer">
                  <span class="product-price">{product.price}</span>
                  <a 
                    href={product.affiliateUrl} 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="btn-primary btn-sm"
                    data-affiliate
                    data-product={product.name}
                    data-network={product.category}
                  >
                    View Product <i class="fas fa-arrow-right"></i>
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- All Products -->
  <section class="store-section">
    <div class="container">
      <h2>All Products</h2>
      <div class="product-grid" id="product-grid">
        {products.filter(p => !p.featured).map(product => (
          <div class="product-card" data-category={product.category} data-name={product.name}>
            {product.badge && (
              <div class="product-badge">{product.badge}</div>
            )}
            <div class="product-image">
              <img 
                src={product.image} 
                alt={product.name}
                loading="lazy"
                onerror="this.src='/images/store/default-product.jpg'"
              />
            </div>
            <div class="product-content">
              <span class="product-category">{product.category}</span>
              <h3>{product.name}</h3>
              <p>{product.description}</p>
              <div class="product-meta">
                <span class="product-rating">
                  {renderStars(product.rating)} {product.rating}
                </span>
                <span class="product-reviews">({product.reviews} reviews)</span>
              </div>
              <div class="product-footer">
                <span class="product-price">{product.price}</span>
                <a 
                  href={product.affiliateUrl} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="btn-primary btn-sm"
                  data-affiliate
                  data-product={product.name}
                  data-network={product.category}
                >
                  Get Product <i class="fas fa-arrow-right"></i>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Suggest a Product Section -->
  <section class="suggest-section">
    <div class="container">
      <div class="suggest-content">
        <h2>📝 Suggest a Product</h2>
        <p>Know a product that should be in our store? Send us your recommendation and help others discover great tools.</p>
        <div class="suggest-actions">
          <a href="mailto:swahilihacks@gmail.com?subject=Product%20Suggestion" class="btn-primary">
            <i class="fas fa-envelope"></i> Suggest a Product
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

