---
// CategoryLayout.astro
//
// Purpose: wraps a single category page's content with BaseLayout + Header +
// "Back to All Tools" link + Footer. This is what used to be duplicated by
// hand at the top and bottom of every category .html file.
//
// What happens if removed: category pages lose their header/footer chrome.
// How to modify safely: change the meta description formula, or the "back"
// link text, here. Don't put category-specific content in this file — that
// belongs in the page templates (SimpleCategory / PlatformCategory / JourneyCategory).

import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Stat {
  number: string;
  label: string;
}

interface Props {
  title: string;
  description: string;
  path: string;
  trustTag: string;
  stats: Stat[];
}

const { title, description, path, trustTag, stats } = Astro.props;
---

<BaseLayout title={title} description={description} path={path}>
  <Header trustTag={trustTag} stats={stats} />

  <div class="container">
    <div class="back-home">
      <a href="/" class="back-btn">
        <i class="fas fa-arrow-left"></i> Back to All Tools
      </a>
    </div>

    <slot />
  </div>

  <Footer />
</BaseLayout>
