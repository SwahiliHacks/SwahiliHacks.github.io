---
// BaseLayout.astro
//
// Purpose: the single place that defines <head> — meta tags, fonts, SEO tags,
// and the global stylesheet. Every page on the site renders through this.
//
// Why it exists: previously every one of the 14 HTML files repeated this
// entire <head> block by hand. Update the font or add a meta tag once, here,
// and it applies everywhere.
//
// What happens if you remove it: pages lose <head> entirely — no styling,
// no fonts, no SEO tags, no favicon.
//
// How to modify safely: add new <meta>/<link> tags inside <head> below. Don't
// remove the `<slot />` in <body> — that's where each page's own content goes.

import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  /** Relative path used to build the canonical + OG image URL, e.g. "trading" */
  path?: string;
  ogImage?: string;
}

const {
  title,
  description,
  path = '',
  ogImage = '/images/sh4.jpg',
} = Astro.props;

const canonicalURL = new URL(path, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Basic Meta -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Site Verification -->
    <meta name="impact-site-verification" value="f4b7e339-23aa-4d6a-b8e6-5ffd3a4d54b2" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="Swahili Hacks" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Icons -->
    <link rel="icon" type="image/png" href="/images/favicon.png" />
    <link rel="apple-touch-icon" href="/images/favicon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Poppins:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Font Awesome Icons -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
      integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
