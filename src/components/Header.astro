---
// Header.astro
//
// Purpose: the profile block + stats bar + navigation at the top of every page.

interface Stat {
  number: string;
  label: string;
}

interface Props {
  trustTag: string;
  stats: Stat[];
}

const { trustTag, stats } = Astro.props;
const defaultTrustTag = 'Trusted by 50,000+ professionals worldwide';
const displayTrustTag = trustTag || defaultTrustTag;
---

<header class="professional-header">
  <div class="header-content">
    <div class="brand-info">
      <!-- Profile Section -->
      <div class="profile-section">
        <div class="profile-image-wrapper">
          <img 
            src="/images/profile.jpg.png" 
            alt="Swahili Hacks - Chemical and Process Engineer" 
            class="profile-img"
            width="500"
            height="500"
            loading="eager"
            decoding="async"
          />
          <div class="profile-ring"></div>
        </div>
        
        <div class="profile-text">
          <h2>
            <a href="/" style="color: inherit; text-decoration: none;" aria-label="Swahili Hacks Home">
              Swahili Hacks
            </a>
          </h2>
          <p class="expert-tag">
            Curated by a <strong>Chemical &amp; Process Engineer</strong>
          </p>
          <p class="trust-tag">
            {displayTrustTag}
          </p>
        </div>
      </div>

      <!-- Stats Section -->
      <div class="header-stats" role="list" aria-label="Key statistics">
        {
          stats.map((stat, index) => (
            <div class="stat" role="listitem" key={index}>
              <span class="stat-number">{stat.number}</span>
              <span class="stat-label">{stat.label}</span>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Navigation - Prominent Store & Bookshelf Cards -->
    <nav class="header-nav" aria-label="Main navigation">
      <ul class="nav-list">
        <!-- Home - Small -->
        <li>
          <a href="/" class="nav-link nav-link-home">Home</a>
        </li>

        <!-- Store - Prominent Card -->
        <li>
          <a href="/store/" class="nav-link nav-link-card nav-link-store">
            <span class="nav-card-icon">🛍️</span>
            <span class="nav-card-title">Store</span>
            <span class="nav-card-subtitle">Curated Products</span>
            <span class="nav-card-arrow">→</span>
          </a>
        </li>

        <!-- Bookshelf - Prominent Card -->
        <li>
          <a href="/bookshelf/" class="nav-link nav-link-card nav-link-bookshelf">
            <span class="nav-card-icon">📚</span>
            <span class="nav-card-title">Bookshelf</span>
            <span class="nav-card-subtitle">Curated Books</span>
            <span class="nav-card-arrow">→</span>
          </a>
        </li>

        <!-- About - Small -->
        <li>
          <a href="/about/" class="nav-link nav-link-about">About</a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  /* ===== HEADER CONTAINER ===== */
  .professional-header {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    color: white;
    padding: 2rem 0 1.5rem 0;
    position: relative;
    overflow: visible;
  }

  .professional-header::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(28, 117, 188, 0.1) 0%, transparent 70%);
  }

  .header-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
    z-index: 1;
  }

  /* ===== BRAND INFO - CENTERED ===== */
  .brand-info {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    gap: 2rem;
  }

  /* ===== PROFILE SECTION - CENTERED ===== */
  .profile-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
  }

  .profile-image-wrapper {
    position: relative;
    display: inline-block;
    flex-shrink: 0;
  }

  .profile-img {
    width: 180px !important;
    height: 180px !important;
    border-radius: 50%;
    border: 6px solid #1C75BC;
    object-fit: cover;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    display: block;
    position: relative;
    z-index: 2;
  }

  .profile-img:hover {
    transform: scale(1.05) rotate(-2deg);
    border-color: #145a8a;
    box-shadow: 0 15px 45px rgba(28, 117, 188, 0.4);
  }

  .profile-ring {
    position: absolute;
    top: -8px;
    left: -8px;
    right: -8px;
    bottom: -8px;
    border-radius: 50%;
    border: 3px solid rgba(28, 117, 188, 0.15);
    animation: ringSpin 20s linear infinite;
    z-index: 1;
    pointer-events: none;
  }

  @keyframes ringSpin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @keyframes profileGlow {
    0%, 100% { 
      box-shadow: 0 0 20px rgba(28, 117, 188, 0.15);
    }
    50% { 
      box-shadow: 0 0 40px rgba(28, 117, 188, 0.3);
    }
  }

  .profile-image-wrapper {
    animation: profileGlow 4s ease-in-out infinite;
  }

  .profile-text h2 {
    color: white;
    font-size: 2.5rem !important;
    margin-bottom: 0.5rem;
    font-weight: 700;
    letter-spacing: -0.5px;
    transition: color 0.3s ease;
  }

  .profile-text h2:hover {
    color: #1C75BC;
  }

  .profile-text h2 a {
    transition: color 0.3s ease;
  }

  .profile-text h2 a:hover {
    color: #1C75BC;
  }

  .expert-tag {
    color: #1C75BC;
    font-size: 1.2rem !important;
    margin-bottom: 0.25rem;
    font-weight: 500;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .expert-tag strong {
    color: white;
    font-weight: 600;
  }

  .trust-tag {
    color: #e2e8f0;
    font-size: 1rem !important;
    opacity: 0.9;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  /* ===== STATS SECTION - CENTERED ===== */
  .header-stats {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2.5rem;
    flex-wrap: wrap;
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
  }

  .stat {
    text-align: center;
    padding: 0.5rem 1rem;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: all 0.3s ease;
    min-width: 80px;
    flex: 1 0 auto;
    max-width: 150px;
  }

  .stat:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: translateY(-3px);
    border-color: rgba(28, 117, 188, 0.3);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);
  }

  .stat-number {
    display: block;
    font-size: 2.2rem !important;
    font-weight: 700;
    color: #1C75BC;
    font-family: 'Poppins', sans-serif;
    line-height: 1.2;
    transition: transform 0.3s ease;
  }

  .stat:hover .stat-number {
    transform: scale(1.05);
  }

  .stat-label {
    font-size: 0.9rem !important;
    color: #e2e8f0;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 400;
    opacity: 0.8;
  }

  /* ===== NAVIGATION ===== */
  .header-nav {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .nav-list {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
    flex-wrap: wrap;
  }

  /* ===== Regular Nav Links (Home & About) ===== */
  .nav-link-home,
  .nav-link-about {
    color: #94a3b8;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    padding: 0.4rem 0.8rem;
    border-radius: 6px;
    transition: all 0.3s ease;
    position: relative;
  }

  .nav-link-home:hover,
  .nav-link-about:hover {
    color: #ffffff;
    background: rgba(255, 255, 255, 0.05);
  }

  .nav-link-home::after,
  .nav-link-about::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 2px;
    background: #1C75BC;
    transition: all 0.3s ease;
    transform: translateX(-50%);
  }

  .nav-link-home:hover::after,
  .nav-link-about:hover::after {
    width: 60%;
  }

  /* ===== Prominent Card Links (Store & Bookshelf) ===== */
  .nav-link-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: white;
    padding: 1rem 1.8rem;
    border-radius: 16px;
    min-width: 140px;
    min-height: 100px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
    border: 2px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(10px);
  }

  .nav-link-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(28, 117, 188, 0.1) 0%, transparent 100%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .nav-link-card:hover {
    transform: translateY(-6px) scale(1.02);
    box-shadow: 0 12px 40px rgba(28, 117, 188, 0.25);
    border-color: #1C75BC;
  }

  .nav-link-card:hover::before {
    opacity: 1;
  }

  .nav-card-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 0.25rem;
    position: relative;
    z-index: 1;
  }

  .nav-card-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: white;
    position: relative;
    z-index: 1;
  }

  .nav-card-subtitle {
    font-size: 0.7rem;
    color: #94a3b8;
    font-weight: 400;
    margin-top: 0.1rem;
    position: relative;
    z-index: 1;
  }

  .nav-card-arrow {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    font-size: 0.9rem;
    color: #94a3b8;
    opacity: 0;
    transform: translateX(-8px);
    transition: all 0.3s ease;
    z-index: 1;
  }

  .nav-link-card:hover .nav-card-arrow {
    opacity: 1;
    transform: translateX(0);
    color: #1C75BC;
  }

  /* Store specific colors */
  .nav-link-store {
    background: rgba(28, 117, 188, 0.08);
    border-color: rgba(28, 117, 188, 0.2);
  }

  .nav-link-store:hover {
    border-color: #1C75BC;
    background: rgba(28, 117, 188, 0.15);
  }

  /* Bookshelf specific colors */
  .nav-link-bookshelf {
    background: rgba(245, 158, 11, 0.06);
    border-color: rgba(245, 158, 11, 0.15);
  }

  .nav-link-bookshelf:hover {
    border-color: #f59e0b;
    background: rgba(245, 158, 11, 0.12);
  }

  .nav-link-bookshelf:hover .nav-card-arrow {
    color: #f59e0b;
  }

  /* ===== RESPONSIVE: TABLET ===== */
  @media (max-width: 1024px) and (min-width: 769px) {
    .nav-list {
      gap: 1.2rem;
    }

    .nav-link-card {
      min-width: 120px;
      min-height: 85px;
      padding: 0.8rem 1.2rem;
    }

    .nav-card-icon {
      font-size: 1.6rem;
    }

    .nav-card-title {
      font-size: 1rem;
    }

    .nav-link-home,
    .nav-link-about {
      font-size: 0.85rem;
      padding: 0.3rem 0.6rem;
    }
  }

  /* ===== RESPONSIVE: MOBILE ===== */
  @media (max-width: 768px) {
    .professional-header {
      padding: 1.5rem 0 1rem 0;
    }

    .profile-img {
      width: 150px !important;
      height: 150px !important;
      border-width: 5px !important;
    }

    .profile-ring {
      top: -6px;
      left: -6px;
      right: -6px;
      bottom: -6px;
      border-width: 2px;
    }

    .profile-text h2 {
      font-size: 2rem !important;
    }

    .expert-tag {
      font-size: 1rem !important;
    }

    .trust-tag {
      font-size: 0.95rem !important;
    }

    .header-stats {
      gap: 1.5rem;
    }

    .stat {
      min-width: 60px;
      padding: 0.75rem 1rem;
      max-width: 120px;
    }

    .stat-number {
      font-size: 1.5rem !important;
    }

    .stat-label {
      font-size: 0.8rem !important;
    }

    .nav-list {
      gap: 1rem;
    }

    .nav-link-card {
      min-width: 100px;
      min-height: 75px;
      padding: 0.6rem 1rem;
    }

    .nav-card-icon {
      font-size: 1.4rem;
    }

    .nav-card-title {
      font-size: 0.9rem;
    }

    .nav-card-subtitle {
      font-size: 0.6rem;
    }

    .nav-link-home,
    .nav-link-about {
      font-size: 0.8rem;
      padding: 0.3rem 0.5rem;
    }

    .nav-card-arrow {
      display: none;
    }

    @keyframes profileGlow {
      0%, 100% { 
        box-shadow: 0 0 15px rgba(28, 117, 188, 0.1);
      }
      50% { 
        box-shadow: 0 0 25px rgba(28, 117, 188, 0.2);
      }
    }
  }

  /* ===== SMALL MOBILE ===== */
  @media (max-width: 480px) {
    .professional-header {
      padding: 1rem 0 0.75rem 0;
    }

    .profile-img {
      width: 130px !important;
      height: 130px !important;
      border-width: 4px !important;
    }

    .profile-ring {
      top: -5px;
      left: -5px;
      right: -5px;
      bottom: -5px;
      border-width: 2px;
      animation-duration: 30s;
    }

    .profile-text h2 {
      font-size: 1.8rem !important;
    }

    .expert-tag {
      font-size: 0.95rem !important;
    }

    .trust-tag {
      font-size: 0.85rem !important;
    }

    .header-stats {
      gap: 1rem;
    }

    .stat {
      min-width: 50px;
      padding: 0.5rem 0.75rem;
      max-width: 100px;
    }

    .stat-number {
      font-size: 1.3rem !important;
    }

    .stat-label {
      font-size: 0.7rem !important;
    }

    .nav-list {
      gap: 0.6rem;
    }

    .nav-link-card {
      min-width: 80px;
      min-height: 60px;
      padding: 0.5rem 0.7rem;
    }

    .nav-card-icon {
      font-size: 1.2rem;
      margin-bottom: 0.1rem;
    }

    .nav-card-title {
      font-size: 0.75rem;
    }

    .nav-card-subtitle {
      display: none;
    }

    .nav-link-home,
    .nav-link-about {
      font-size: 0.7rem;
      padding: 0.2rem 0.4rem;
    }
  }
</style>
