---
// Header.astro
//
// Purpose: the profile block + stats bar + navigation at the top of every page.

import Navigation from './Navigation.astro';

interface Stat {
  number: string;
  label: string;
}

interface Props {
  trustTag: string;
  stats: Stat[];
}

const { trustTag, stats } = Astro.props;
const defaultTrustTag = 'Trusted by 50,000+ professionals worldwide';
const displayTrustTag = trustTag || defaultTrustTag;
---

<header class="professional-header">
  <!-- Animated Background Particles -->
  <div class="animated-bg">
    <div class="particle particle-1">📈</div>
    <div class="particle particle-2">💻</div>
    <div class="particle particle-3">📊</div>
    <div class="particle particle-4">🤖</div>
    <div class="particle particle-5">💰</div>
    <div class="particle particle-6">📚</div>
    <div class="particle particle-7">⚡</div>
    <div class="particle particle-8">🛒</div>
    <div class="particle particle-9">🌍</div>
    <div class="particle particle-10">🎯</div>
  </div>

  <div class="header-content">
    <!-- Profile Section -->
    <div class="brand-info">
      <div class="profile-section">
        <div class="profile-image-wrapper">
          <!-- Use a circular cropped version or add a background mask -->
          <div class="profile-img-container">
            <img 
              src="/images/profile.jpg.png" 
              alt="Swahili Hacks - Chemical and Process Engineer" 
              class="profile-img"
              width="500"
              height="500"
              loading="eager"
              decoding="async"
            />
            <!-- This overlay ensures any background is hidden -->
            <div class="img-overlay"></div>
          </div>
          <div class="profile-ring"></div>
        </div>
        
        <div class="profile-text">
          <h2>
            <a href="/" style="color: inherit; text-decoration: none;" aria-label="Swahili Hacks Home">
              Swahili Hacks
            </a>
          </h2>
          <p class="expert-tag">
            Curated by a <strong>Chemical &amp; Process Engineer</strong>
          </p>
          <p class="trust-tag">
            {displayTrustTag}
          </p>
        </div>
      </div>

      <!-- Stats Section -->
      <div class="header-stats" role="list" aria-label="Key statistics">
        {
          stats.map((stat, index) => (
            <div class="stat" role="listitem" key={index}>
              <span class="stat-number">{stat.number}</span>
              <span class="stat-label">{stat.label}</span>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Navigation - Full width below stats -->
    <Navigation />
  </div>
</header>

<style>
  /* ===== HEADER CONTAINER ===== */
  .professional-header {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    color: white;
    padding: 2rem 0 0 0;
    position: relative;
    overflow: visible;
    min-height: 400px;
  }

  .professional-header::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(28, 117, 188, 0.1) 0%, transparent 70%);
  }

  /* ===== ANIMATED BACKGROUND PARTICLES ===== */
  .animated-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    z-index: 0;
    pointer-events: none;
  }

  .particle {
    position: absolute;
    font-size: 2.5rem;
    opacity: 0.08;
    animation: floatParticle 20s ease-in-out infinite;
    filter: blur(1px);
    will-change: transform;
  }

  .particle-1 {
    top: 10%;
    left: 5%;
    animation-delay: 0s;
    font-size: 3rem;
  }

  .particle-2 {
    top: 20%;
    right: 8%;
    animation-delay: 2s;
    font-size: 2.8rem;
  }

  .particle-3 {
    bottom: 30%;
    left: 15%;
    animation-delay: 4s;
    font-size: 3.2rem;
  }

  .particle-4 {
    top: 60%;
    right: 5%;
    animation-delay: 1s;
    font-size: 2.5rem;
  }

  .particle-5 {
    top: 5%;
    left: 50%;
    animation-delay: 3s;
    font-size: 2.2rem;
  }

  .particle-6 {
    bottom: 20%;
    right: 20%;
    animation-delay: 5s;
    font-size: 3.5rem;
  }

  .particle-7 {
    top: 40%;
    left: 3%;
    animation-delay: 2.5s;
    font-size: 2rem;
  }

  .particle-8 {
    bottom: 10%;
    left: 40%;
    animation-delay: 4.5s;
    font-size: 2.8rem;
  }

  .particle-9 {
    top: 70%;
    left: 25%;
    animation-delay: 1.5s;
    font-size: 2.3rem;
  }

  .particle-10 {
    top: 15%;
    right: 30%;
    animation-delay: 3.5s;
    font-size: 2.6rem;
  }

  @keyframes floatParticle {
    0% {
      transform: translate(0, 0) rotate(0deg) scale(1);
    }
    25% {
      transform: translate(50px, -30px) rotate(90deg) scale(1.1);
    }
    50% {
      transform: translate(-30px, 50px) rotate(180deg) scale(0.9);
    }
    75% {
      transform: translate(40px, -20px) rotate(270deg) scale(1.05);
    }
    100% {
      transform: translate(0, 0) rotate(360deg) scale(1);
    }
  }

  .header-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
    z-index: 1;
  }

  /* ===== BRAND INFO - CENTERED ===== */
  .brand-info {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    gap: 2rem;
    width: 100%;
  }

  /* ===== PROFILE SECTION - CENTERED ===== */
  .profile-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
    width: 100%;
  }

  .profile-image-wrapper {
    position: relative;
    display: inline-block;
    flex-shrink: 0;
  }

  /* Profile Image Container - Ensures circular clipping */
  .profile-img-container {
    position: relative;
    width: 180px;
    height: 180px;
    border-radius: 50%;
    overflow: hidden;
    background: transparent !important;
    z-index: 2;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
  }

  .profile-img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover;
    display: block;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    z-index: 2;
    background: transparent !important;
  }

  /* Overlay to hide any background artifacts */
  .img-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border: 6px solid #1C75BC;
    box-sizing: border-box;
    pointer-events: none;
    z-index: 3;
    box-shadow: inset 0 0 30px rgba(28, 117, 188, 0.1);
  }

  .profile-img-container:hover .profile-img {
    transform: scale(1.05) rotate(-2deg);
  }

  .profile-img-container:hover {
    box-shadow: 0 15px 45px rgba(28, 117, 188, 0.4);
  }

  .profile-ring {
    position: absolute;
    top: -8px;
    left: -8px;
    right: -8px;
    bottom: -8px;
    border-radius: 50%;
    border: 3px solid rgba(28, 117, 188, 0.15);
    animation: ringSpin 20s linear infinite;
    z-index: 1;
    pointer-events: none;
    background: transparent !important;
  }

  @keyframes ringSpin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @keyframes profileGlow {
    0%, 100% { 
      box-shadow: 0 0 20px rgba(28, 117, 188, 0.15);
    }
    50% { 
      box-shadow: 0 0 40px rgba(28, 117, 188, 0.3);
    }
  }

  .profile-image-wrapper {
    animation: profileGlow 4s ease-in-out infinite;
  }

  .profile-text h2 {
    color: white;
    font-size: 2.5rem !important;
    margin-bottom: 0.5rem;
    font-weight: 700;
    letter-spacing: -0.5px;
    transition: color 0.3s ease;
  }

  .profile-text h2:hover {
    color: #1C75BC;
  }

  .profile-text h2 a {
    transition: color 0.3s ease;
  }

  .profile-text h2 a:hover {
    color: #1C75BC;
  }

  .expert-tag {
    color: #1C75BC;
    font-size: 1.2rem !important;
    margin-bottom: 0.25rem;
    font-weight: 500;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .expert-tag strong {
    color: white;
    font-weight: 600;
  }

  .trust-tag {
    color: #e2e8f0;
    font-size: 1rem !important;
    opacity: 0.9;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  /* ===== STATS SECTION - CENTERED ===== */
  .header-stats {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2.5rem;
    flex-wrap: wrap;
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
  }

  .stat {
    text-align: center;
    padding: 0.5rem 1rem;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: all 0.3s ease;
    min-width: 80px;
    flex: 1 0 auto;
    max-width: 150px;
  }

  .stat:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: translateY(-3px);
    border-color: rgba(28, 117, 188, 0.3);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);
  }

  .stat-number {
    display: block;
    font-size: 2.2rem !important;
    font-weight: 700;
    color: #1C75BC;
    font-family: 'Poppins', sans-serif;
    line-height: 1.2;
    transition: transform 0.3s ease;
  }

  .stat:hover .stat-number {
    transform: scale(1.05);
  }

  .stat-label {
    font-size: 0.9rem !important;
    color: #e2e8f0;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 400;
    opacity: 0.8;
  }

  /* ===== RESPONSIVE: TABLET ===== */
  @media (max-width: 1024px) and (min-width: 769px) {
    .brand-info {
      gap: 1.5rem;
    }

    .header-stats {
      gap: 1.5rem;
    }

    .stat {
      min-width: 70px;
      padding: 0.5rem 0.75rem;
      max-width: 120px;
    }

    .stat-number {
      font-size: 1.8rem !important;
    }

    .profile-img-container {
      width: 160px;
      height: 160px;
    }

    .profile-text h2 {
      font-size: 2.2rem !important;
    }

    .particle {
      font-size: 1.8rem !important;
      opacity: 0.06 !important;
    }
  }

  /* ===== RESPONSIVE: MOBILE (768px and below) ===== */
  @media (max-width: 768px) {
    .professional-header {
      padding: 1.5rem 0 0 0;
      min-height: 350px;
    }

    .profile-img-container {
      width: 150px;
      height: 150px;
    }

    .profile-ring {
      top: -6px;
      left: -6px;
      right: -6px;
      bottom: -6px;
      border-width: 2px;
    }

    .profile-text h2 {
      font-size: 2rem !important;
    }

    .expert-tag {
      font-size: 1rem !important;
    }

    .trust-tag {
      font-size: 0.95rem !important;
    }

    .header-stats {
      gap: 1.5rem;
    }

    .stat {
      min-width: 60px;
      padding: 0.75rem 1rem;
      max-width: 120px;
    }

    .stat-number {
      font-size: 1.5rem !important;
    }

    .stat-label {
      font-size: 0.8rem !important;
    }

    .particle {
      font-size: 1.8rem !important;
      opacity: 0.05 !important;
    }

    .particle-1, .particle-2, .particle-3, .particle-4, .particle-5,
    .particle-6, .particle-7, .particle-8, .particle-9, .particle-10 {
      display: block !important;
    }

    @keyframes profileGlow {
      0%, 100% { 
        box-shadow: 0 0 15px rgba(28, 117, 188, 0.1);
      }
      50% { 
        box-shadow: 0 0 25px rgba(28, 117, 188, 0.2);
      }
    }
  }

  /* ===== SMALL MOBILE (480px and below) ===== */
  @media (max-width: 480px) {
    .professional-header {
      padding: 1rem 0 0 0;
      min-height: 300px;
    }

    .profile-img-container {
      width: 130px;
      height: 130px;
    }

    .profile-ring {
      top: -5px;
      left: -5px;
      right: -5px;
      bottom: -5px;
      border-width: 2px;
      animation-duration: 30s;
    }

    .profile-text h2 {
      font-size: 1.8rem !important;
    }

    .expert-tag {
      font-size: 0.95rem !important;
    }

    .trust-tag {
      font-size: 0.85rem !important;
    }

    .header-stats {
      gap: 1rem;
    }

    .stat {
      min-width: 50px;
      padding: 0.5rem 0.75rem;
      max-width: 100px;
    }

    .stat-number {
      font-size: 1.3rem !important;
    }

    .stat-label {
      font-size: 0.7rem !important;
    }

    .particle {
      font-size: 1.2rem !important;
      opacity: 0.04 !important;
    }

    .particle-1, .particle-2, .particle-3, .particle-4, .particle-5,
    .particle-6, .particle-7, .particle-8, .particle-9, .particle-10 {
      display: block !important;
    }

    .particle-1 { top: 5%; left: 3%; }
    .particle-2 { top: 10%; right: 3%; }
    .particle-3 { bottom: 40%; left: 5%; }
    .particle-4 { top: 50%; right: 3%; }
    .particle-5 { top: 3%; left: 40%; }
    .particle-6 { bottom: 30%; right: 8%; }
    .particle-7 { top: 30%; left: 2%; }
    .particle-8 { bottom: 15%; left: 30%; }
    .particle-9 { top: 65%; left: 10%; }
    .particle-10 { top: 8%; right: 20%; }
  }
</style>
