---
// Header.astro
//
// Purpose: the profile block + stats bar at the top of every page.
// Why it exists: was copy-pasted at the top of all 14 HTML files before.
// What happens if removed: pages lose the brand header entirely.
// How to modify safely: change props per-page (trustTag, stats) rather than
// editing this file, unless you're changing something for the whole site
// (e.g. the profile photo or name).

// UPDATES MADE (2026-07-20):
// 1. Removed all emojis (👨‍🔬, ✨, ⚡)
// 2. Replaced green (#22c55e) with primary blue (#1C75BC)
// 3. Professional clean design
// 4. Fixed header alignment for tablet and desktop

interface Stat {
  number: string;
  label: string;
}

interface Props {
  trustTag: string;
  stats: Stat[];
}

const { trustTag, stats } = Astro.props;
const defaultTrustTag = 'Trusted by 50,000+ professionals worldwide';
const displayTrustTag = trustTag || defaultTrustTag;
---

<header class="professional-header">
  <div class="header-content">
    <div class="brand-info">
      <!-- Profile Section -->
      <div class="profile-section">
        <div class="profile-image-wrapper">
          <img 
            src="/images/profile.jpg.png" 
            alt="Swahili Hacks - Chemical and Process Engineer" 
            class="profile-img"
            width="500"
            height="500"
            loading="eager"
            decoding="async"
          />
          <div class="profile-ring"></div>
        </div>
        
        <div class="profile-text">
          <h2>
            <a href="/" style="color: inherit; text-decoration: none;" aria-label="Swahili Hacks Home">
              Swahili Hacks
            </a>
          </h2>
          <p class="expert-tag">
            Curated by a <strong>Chemical &amp; Process Engineer</strong>
          </p>
          <p class="trust-tag">
            {displayTrustTag}
          </p>
        </div>
      </div>

      <!-- Stats Section -->
      <div class="header-stats" role="list" aria-label="Key statistics">
        {
          stats.map((stat, index) => (
            <div class="stat" role="listitem" key={index}>
              <span class="stat-number">{stat.number}</span>
              <span class="stat-label">{stat.label}</span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</header>

<style>
  /* ===== HEADER CONTAINER ===== */
  .professional-header {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    color: white;
    padding: 2rem 0;
    position: relative;
    overflow: hidden;
  }

  .professional-header::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(28, 117, 188, 0.1) 0%, transparent 70%);
  }

  .header-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* ===== BRAND INFO ===== */
  .brand-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 2rem;
  }

  /* ===== PROFILE SECTION ===== */
  .profile-section {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .profile-image-wrapper {
    position: relative;
    display: inline-block;
    flex-shrink: 0;
  }

  .profile-img {
    width: 180px !important;
    height: 180px !important;
    border-radius: 50%;
    border: 6px solid #1C75BC;
    object-fit: cover;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    display: block;
    position: relative;
    z-index: 2;
  }

  .profile-img:hover {
    transform: scale(1.05) rotate(-2deg);
    border-color: #145a8a;
    box-shadow: 0 15px 45px rgba(28, 117, 188, 0.4);
  }

  .profile-ring {
    position: absolute;
    top: -8px;
    left: -8px;
    right: -8px;
    bottom: -8px;
    border-radius: 50%;
    border: 3px solid rgba(28, 117, 188, 0.15);
    animation: ringSpin 20s linear infinite;
    z-index: 1;
    pointer-events: none;
  }

  @keyframes ringSpin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @keyframes profileGlow {
    0%, 100% { 
      box-shadow: 0 0 20px rgba(28, 117, 188, 0.15);
    }
    50% { 
      box-shadow: 0 0 40px rgba(28, 117, 188, 0.3);
    }
  }

  .profile-image-wrapper {
    animation: profileGlow 4s ease-in-out infinite;
  }

  .profile-text h2 {
    color: white;
    font-size: 2.5rem !important;
    margin-bottom: 0.5rem;
    font-weight: 700;
    letter-spacing: -0.5px;
    transition: color 0.3s ease;
  }

  .profile-text h2:hover {
    color: #1C75BC;
  }

  .profile-text h2 a {
    transition: color 0.3s ease;
  }

  .profile-text h2 a:hover {
    color: #1C75BC;
  }

  .expert-tag {
    color: #1C75BC;
    font-size: 1.2rem !important;
    margin-bottom: 0.25rem;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .expert-tag strong {
    color: white;
    font-weight: 600;
  }

  .trust-tag {
    color: #e2e8f0;
    font-size: 1rem !important;
    opacity: 0.9;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* ===== STATS SECTION ===== */
  .header-stats {
    display: flex;
    gap: 2.5rem;
    align-items: center;
    flex-shrink: 0;
  }

  .stat {
    text-align: center;
    padding: 0.5rem 1rem;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: all 0.3s ease;
    min-width: 80px;
  }

  .stat:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: translateY(-3px);
    border-color: rgba(28, 117, 188, 0.3);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);
  }

  .stat-number {
    display: block;
    font-size: 2.2rem !important;
    font-weight: 700;
    color: #1C75BC;
    font-family: 'Poppins', sans-serif;
    line-height: 1.2;
    transition: transform 0.3s ease;
  }

  .stat:hover .stat-number {
    transform: scale(1.05);
  }

  .stat-label {
    font-size: 0.9rem !important;
    color: #e2e8f0;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 400;
    opacity: 0.8;
  }

  /* ===== DESKTOP (1025px+) - Already working ===== */
  /* No changes needed for desktop */

  /* ===== TABLET (769px - 1024px) - FIXED ===== */
  @media (max-width: 1024px) and (min-width: 769px) {
    .brand-info {
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      gap: 2rem;
    }

    .profile-section {
      flex-direction: column;
      text-align: center;
      gap: 1.5rem;
    }

    .profile-text h2 {
      font-size: 2.2rem !important;
    }

    .expert-tag {
      justify-content: center;
      font-size: 1.1rem !important;
    }

    .trust-tag {
      justify-content: center;
      font-size: 0.95rem !important;
    }

    .header-stats {
      justify-content: center;
      gap: 2rem;
      flex-wrap: wrap;
      width: 100%;
    }

    .stat {
      min-width: 80px;
      padding: 0.75rem 1.25rem;
      flex: 1 0 auto;
      max-width: 150px;
    }

    .stat-number {
      font-size: 1.8rem !important;
    }

    .stat-label {
      font-size: 0.8rem !important;
    }
  }

  /* ===== MOBILE (768px and below) ===== */
  @media (max-width: 768px) {
    .brand-info {
      flex-direction: column;
      text-align: center;
      gap: 2rem;
    }

    .profile-section {
      flex-direction: column;
      text-align: center;
      gap: 1.5rem;
    }

    .profile-img {
      width: 150px !important;
      height: 150px !important;
      border-width: 5px !important;
    }

    .profile-ring {
      top: -6px;
      left: -6px;
      right: -6px;
      bottom: -6px;
      border-width: 2px;
    }

    .profile-text h2 {
      font-size: 2rem !important;
    }

    .expert-tag {
      font-size: 1rem !important;
      justify-content: center;
    }

    .trust-tag {
      font-size: 0.95rem !important;
      justify-content: center;
    }

    .header-stats {
      justify-content: center;
      gap: 1.5rem;
      flex-wrap: wrap;
      width: 100%;
    }

    .stat {
      min-width: 60px;
      padding: 0.75rem 1rem;
      flex: 1 0 auto;
      max-width: 130px;
    }

    .stat-number {
      font-size: 1.5rem !important;
    }

    .stat-label {
      font-size: 0.8rem !important;
    }

    @keyframes profileGlow {
      0%, 100% { 
        box-shadow: 0 0 15px rgba(28, 117, 188, 0.1);
      }
      50% { 
        box-shadow: 0 0 25px rgba(28, 117, 188, 0.2);
      }
    }
  }

  /* ===== SMALL MOBILE (480px and below) ===== */
  @media (max-width: 480px) {
    .profile-img {
      width: 130px !important;
      height: 130px !important;
      border-width: 4px !important;
    }

    .profile-ring {
      top: -5px;
      left: -5px;
      right: -5px;
      bottom: -5px;
      border-width: 2px;
      animation-duration: 30s;
    }

    .profile-text h2 {
      font-size: 1.8rem !important;
    }

    .expert-tag {
      font-size: 0.95rem !important;
      flex-wrap: wrap;
      justify-content: center;
    }

    .trust-tag {
      font-size: 0.85rem !important;
    }

    .header-stats {
      gap: 1rem;
    }

    .stat {
      min-width: 50px;
      padding: 0.5rem 0.75rem;
      max-width: 100px;
    }

    .stat-number {
      font-size: 1.3rem !important;
    }

    .stat-label {
      font-size: 0.7rem !important;
    }
  }
</style>
