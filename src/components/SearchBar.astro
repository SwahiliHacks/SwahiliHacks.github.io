---
// src/components/SearchBar.astro
// Purpose: Search, filter and sort functionality for categories and products

interface Props {
  placeholder?: string;
  categories?: any[];
}

const { placeholder = 'Search solutions, tools, or problems...', categories = [] } = Astro.props;
---

<div class="search-container" id="search-container">
  <div class="search-input-wrapper">
    <i class="fas fa-search search-icon"></i>
    <input 
      type="text" 
      id="search-input" 
      class="search-input" 
      placeholder={placeholder}
      aria-label="Search"
    />
    <button class="search-clear" id="search-clear" aria-label="Clear search">
      <i class="fas fa-times"></i>
    </button>
  </div>

  <div class="search-filters">
    <div class="filter-group">
      <label for="category-filter">Category</label>
      <select id="category-filter" class="filter-select">
        <option value="all">All Categories</option>
        {categories.map((category) => (
          <option value={category.id}>{category.data.nav_label}</option>
        ))}
      </select>
    </div>

    <div class="filter-group">
      <label for="sort-filter">Sort By</label>
      <select id="sort-filter" class="filter-select">
        <option value="relevance">Relevance</option>
        <option value="popular">Most Popular</option>
        <option value="newest">Newest</option>
        <option value="rating">Highest Rated</option>
      </select>
    </div>

    <button class="filter-toggle" id="filter-toggle" aria-label="Toggle filters">
      <i class="fas fa-sliders-h"></i>
      <span>Filters</span>
    </button>
  </div>

  <div class="search-results" id="search-results">
    <div class="results-count" id="results-count"></div>
    <div class="results-grid" id="results-grid"></div>
  </div>
</div>

<style>
  .search-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 20px;
  }

  .search-input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    background: #f8fafc;
    border: 2px solid #e2e8f0;
    border-radius: 12px;
    transition: all 0.3s ease;
  }

  .search-input-wrapper:focus-within {
    border-color: #1C75BC;
    box-shadow: 0 0 0 3px rgba(28, 117, 188, 0.1);
  }

  .search-icon {
    position: absolute;
    left: 1rem;
    color: #94a3b8;
  }

  .search-input {
    width: 100%;
    padding: 0.9rem 1rem 0.9rem 3rem;
    border: none;
    background: transparent;
    font-size: 1rem;
    outline: none;
    color: #0f172a;
  }

  .search-input::placeholder {
    color: #94a3b8;
  }

  .search-clear {
    position: absolute;
    right: 1rem;
    background: none;
    border: none;
    color: #94a3b8;
    cursor: pointer;
    display: none;
    padding: 0.25rem;
  }

  .search-clear.visible {
    display: block;
  }

  .search-clear:hover {
    color: #0f172a;
  }

  .search-filters {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .filter-group {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .filter-group label {
    font-size: 0.85rem;
    font-weight: 600;
    color: #475569;
  }

  .filter-select {
    padding: 0.5rem 1rem;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    background: white;
    font-size: 0.85rem;
    color: #0f172a;
    outline: none;
    transition: all 0.3s ease;
  }

  .filter-select:focus {
    border-color: #1C75BC;
    box-shadow: 0 0 0 3px rgba(28, 117, 188, 0.1);
  }

  .filter-toggle {
    display: none;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    cursor: pointer;
    font-weight: 500;
    color: #475569;
    transition: all 0.3s ease;
  }

  .filter-toggle:hover {
    background: #e2e8f0;
  }

  .search-results {
    margin-top: 2rem;
  }

  .results-count {
    font-size: 0.9rem;
    color: #64748b;
    margin-bottom: 1rem;
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .result-item {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 1.5rem;
    transition: all 0.3s ease;
    text-decoration: none;
    color: #0f172a;
  }

  .result-item:hover {
    border-color: #1C75BC;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.06);
    transform: translateY(-4px);
  }

  .result-item .icon {
    font-size: 2rem;
    color: #1C75BC;
    margin-bottom: 0.5rem;
  }

  .result-item h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .result-item p {
    font-size: 0.9rem;
    color: #64748b;
  }

  .result-item .badge {
    display: inline-block;
    padding: 0.15rem 0.6rem;
    background: #eef2ff;
    color: #1C75BC;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 600;
    margin-top: 0.5rem;
  }

  .result-item .match-highlight {
    background: #fef9e7;
    padding: 0.1rem 0.2rem;
    border-radius: 2px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .search-filters {
      flex-direction: column;
      align-items: stretch;
    }

    .filter-group {
      flex-wrap: wrap;
    }

    .filter-select {
      flex: 1;
    }

    .results-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('search-input');
    const searchClear = document.getElementById('search-clear');
    const categoryFilter = document.getElementById('category-filter');
    const sortFilter = document.getElementById('sort-filter');
    const resultsGrid = document.getElementById('results-grid');
    const resultsCount = document.getElementById('results-count');
    const filterToggle = document.getElementById('filter-toggle');
    const filterGroups = document.querySelector('.search-filters');

    // Get all categories data
    const categoriesData = JSON.parse(document.getElementById('categories-data')?.textContent || '[]');

    // Show/hide clear button
    searchInput.addEventListener('input', function() {
      searchClear.classList.toggle('visible', this.value.length > 0);
      performSearch();
    });

    searchClear.addEventListener('click', function() {
      searchInput.value = '';
      searchClear.classList.remove('visible');
      performSearch();
    });

    categoryFilter.addEventListener('change', performSearch);
    sortFilter.addEventListener('change', performSearch);

    // Toggle filters on mobile
    filterToggle.addEventListener('click', function() {
      const isVisible = filterGroups.style.display !== 'none';
      filterGroups.style.display = isVisible ? 'none' : 'flex';
      this.classList.toggle('active');
    });

    function performSearch() {
      const query = searchInput.value.toLowerCase().trim();
      const category = categoryFilter.value;
      const sort = sortFilter.value;

      let results = categoriesData;

      // Filter by search query
      if (query) {
        results = results.filter(item => {
          const title = item.data.nav_label?.toLowerCase() || '';
          const teaser = item.data.card_teaser?.toLowerCase() || '';
          const bullets = item.data.card_bullets?.join(' ').toLowerCase() || '';
          const intro = item.data.intro?.toLowerCase() || '';
          return title.includes(query) || 
                 teaser.includes(query) || 
                 bullets.includes(query) || 
                 intro.includes(query);
        });
      }

      // Filter by category
      if (category !== 'all') {
        results = results.filter(item => item.id === category);
      }

      // Sort results
      results = sortResults(results, sort);

      // Render results
      renderResults(results, query);
    }

    function sortResults(results, sort) {
      switch(sort) {
        case 'popular':
          return results.sort((a, b) => (b.data.stats?.[0]?.number || 0) - (a.data.stats?.[0]?.number || 0));
        case 'newest':
          return results.sort((a, b) => (b.id || '').localeCompare(a.id || ''));
        case 'rating':
          return results.sort((a, b) => (b.data.rating_stars || 0) - (a.data.rating_stars || 0));
        default: // relevance
          return results;
      }
    }

    function renderResults(results, query) {
      if (results.length === 0) {
        resultsGrid.innerHTML = `
          <div class="no-results" style="grid-column: 1/-1; text-align: center; padding: 3rem; color: #64748b;">
            <i class="fas fa-search" style="font-size: 2rem; display: block; margin-bottom: 1rem;"></i>
            <h3>No results found</h3>
            <p>Try adjusting your search or filters</p>
          </div>
        `;
        resultsCount.textContent = '0 results found';
        return;
      }

      resultsCount.textContent = `${results.length} result${results.length > 1 ? 's' : ''} found`;

      resultsGrid.innerHTML = results.map(item => {
        const title = item.data.nav_label || item.id;
        const teaser = item.data.card_teaser || '';
        const icon = item.data.icon || 'fas fa-tag';
        const slug = item.id;

        // Highlight matching text
        let displayTitle = title;
        let displayTeaser = teaser;
        if (query) {
          const regex = new RegExp(`(${query})`, 'gi');
          displayTitle = title.replace(regex, '<span class="match-highlight">$1</span>');
          displayTeaser = teaser.replace(regex, '<span class="match-highlight">$1</span>');
        }

        return `
          <a href="/${slug}/" class="result-item">
            <div class="icon"><i class="${icon}"></i></div>
            <h3>${displayTitle}</h3>
            <p>${displayTeaser}</p>
            <span class="badge">${item.data.type || 'platform'}</span>
          </a>
        `;
      }).join('');
    }

    // Initial render
    performSearch();
  });
</script>
