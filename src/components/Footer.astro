---
// Footer.astro
//
// Purpose: contact info + social links + copyright, shared by every page.
// Why it exists: was copy-pasted at the bottom of all 14 HTML files before.
// What happens if removed: pages lose contact/social info and the copyright line.
// How to modify safely: this is the ONE place to update phone number, email,
// or social handles. Edit here and it updates on all pages instantly.

// UPDATES MADE (2026-07-20):
// 1. Removed emoji (🚀) from brand name
// 2. Clean professional design

interface Props {
  tagline?: string;
}

const { tagline = 'Empowering entrepreneurs with professional tools and expert guidance.' } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="footer professional-footer">
  <div class="footer-container">
    <!-- Brand Section -->
    <div class="footer-brand">
      <h3>Swahili Hacks</h3>
      <p class="tagline">{tagline}</p>

      <div class="contact">
        <p>
          <i class="fas fa-envelope" aria-hidden="true"></i>
          <strong>Email:</strong>
          <a href="mailto:swahilihacks@gmail.com" aria-label="Email Swahili Hacks">
            swahilihacks@gmail.com
          </a>
        </p>

        <p>
          <i class="fas fa-phone" aria-hidden="true"></i>
          <strong>Call:</strong>
          <a href="tel:+255653828162" aria-label="Call Swahili Hacks">
            +255 653 828 162
          </a>
        </p>

        <p>
          <i class="fab fa-whatsapp" aria-hidden="true"></i>
          <strong>WhatsApp:</strong>
          <a href="https://wa.me/255653828162" target="_blank" rel="noopener noreferrer" aria-label="Chat on WhatsApp">
            Chat on WhatsApp
          </a>
        </p>
      </div>
    </div>

    <!-- Social Section -->
    <div class="footer-social">
      <h4>Connect With Us</h4>
      <div class="social-icons professional-icons">
        <a href="https://www.youtube.com/@SwahiliHacks" target="_blank" rel="noopener noreferrer" aria-label="Subscribe on YouTube">
          <i class="fab fa-youtube"></i>
        </a>
        <a href="https://instagram.com/SwahiliHacks" target="_blank" rel="noopener noreferrer" aria-label="Follow on Instagram">
          <i class="fab fa-instagram"></i>
        </a>
        <a href="https://tiktok.com/@SwahiliHacks" target="_blank" rel="noopener noreferrer" aria-label="Follow on TikTok">
          <i class="fab fa-tiktok"></i>
        </a>
        <a href="https://twitter.com/SwahiliHacks" target="_blank" rel="noopener noreferrer" aria-label="Follow on X">
          <i class="fab fa-x-twitter"></i>
        </a>
        <a href="https://facebook.com/SwahiliHacks" target="_blank" rel="noopener noreferrer" aria-label="Like on Facebook">
          <i class="fab fa-facebook"></i>
        </a>
        <a href="https://linktr.ee/swahilihacks" target="_blank" rel="noopener noreferrer" aria-label="All links on Linktree">
          <i class="fas fa-link"></i>
        </a>
      </div>

      <!-- SH4 Image -->
      <div class="sh4-image-container wide-image">
        <img 
          src="/images/sh4.jpg" 
          alt="SH4 - Swahili Hacks Brand Logo" 
          class="sh4-image"
          loading="lazy"
          width="400"
          height="150"
        />
      </div>
    </div>
  </div>

  <!-- Footer Bottom -->
  <div class="footer-bottom">
    <p class="copyright">
      &copy; {year} <strong>Swahili Hacks</strong>. All rights reserved. 
      <span class="separator">|</span> 
      Empowering entrepreneurs worldwide.
    </p>
  </div>
</footer>

<style>
  /* Additional footer enhancements */
  .footer-brand .tagline {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1.05rem;
    line-height: 1.6;
    margin-bottom: 2rem;
    font-weight: 300;
  }

  .footer-brand h3 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: white;
  }

  .footer-social h4 {
    font-size: 1.3rem;
    font-weight: 600;
  }

  /* Contact items hover effect */
  .contact a {
    transition: all 0.3s ease;
    position: relative;
  }

  .contact a:hover {
    color: #1C75BC !important;
    transform: translateX(5px);
  }

  /* Social icons enhanced hover */
  .social-icons.professional-icons a {
    position: relative;
    overflow: hidden;
  }

  .social-icons.professional-icons a::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: #1C75BC;
    border-radius: 50%;
    transform: scale(0);
    transition: transform 0.3s ease;
    z-index: -1;
  }

  .social-icons.professional-icons a:hover::before {
    transform: scale(1);
  }

  .social-icons.professional-icons a:hover {
    transform: translateY(-5px) scale(1.1);
    box-shadow: 0 10px 25px rgba(28, 117, 188, 0.3);
  }

  /* Separator in copyright */
  .separator {
    color: #64748b;
    margin: 0 0.5rem;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .footer-brand h3 {
      font-size: 1.8rem;
    }

    .footer-brand .tagline {
      font-size: 0.95rem;
    }

    .footer-bottom .copyright {
      font-size: 0.85rem;
      line-height: 1.6;
    }

    .separator {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .footer-brand h3 {
      font-size: 1.5rem;
    }

    .footer-brand .tagline {
      font-size: 0.9rem;
    }

    .contact p {
      font-size: 0.85rem;
    }

    .footer-social h4 {
      font-size: 1.1rem;
    }

    .social-icons.professional-icons a {
      width: 40px;
      height: 40px;
      font-size: 1rem;
    }
  }
</style>
