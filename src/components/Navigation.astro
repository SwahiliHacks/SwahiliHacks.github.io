---
// src/components/Navigation.astro
// Purpose: Clean navigation bar with dropdowns - BLUE accents

const currentPath = Astro.url.pathname;

const navItems = [
  {
    label: 'Solutions',
    url: '/solutions/',
    dropdown: [
      { label: 'Wealth & Investment', url: '/wealth-investment/' },
      { label: 'Automated Wealth Systems', url: '/automated-wealth-systems/' },
      { label: 'Digital Income & Monetization', url: '/digital-income-monetization/' },
      { label: 'Freelancing & Professional Services', url: '/freelancing-professional-services/' },
      { label: 'E-commerce & Online Business', url: '/ecommerce-online-business/' },
      { label: 'AI & Intelligent Automation', url: '/ai-intelligent-automation/' },
      { label: 'Content Creation & Digital Media', url: '/content-creation-digital-media/' },
      { label: 'Productivity & Workflow Systems', url: '/productivity-workflow-systems/' },
      { label: 'Remote Work & Distributed Teams', url: '/remote-work-distributed-teams/' },
      { label: 'Career Growth & Skills Development', url: '/career-growth-skills-development/' },
      { label: 'Personal Finance & Money Management', url: '/personal-finance-money-management/' },
      { label: 'Online Income Opportunities', url: '/online-income-opportunities/' },
    ]
  },
  {
    label: 'Shop',
    url: '/shop/',
    dropdown: [
      { label: 'Electronics & Gadgets', url: '/shop/electronics/' },
      { label: 'Home & Kitchen', url: '/shop/home-kitchen/' },
      { label: 'Solar & Energy', url: '/shop/solar-energy/' },
      { label: 'Agriculture', url: '/shop/agriculture/' },
      { label: 'Fashion & Wear', url: '/shop/fashion-wear/' },
      { label: 'Health & Fitness', url: '/shop/health-fitness/' },
      { label: 'Beauty & Personal Care', url: '/shop/beauty-care/' },
      { label: 'Automotive & Motorcycle', url: '/shop/automotive/' },
      { label: 'Office & Stationery', url: '/shop/office-stationery/' },
    ]
  },
  {
    label: 'Bookshelf',
    url: '/bookshelf/',
    dropdown: [
      { label: 'Trading & Investing', url: '/bookshelf/trading-investing/' },
      { label: 'Finance & Wealth', url: '/bookshelf/finance-wealth/' },
      { label: 'Personal Development', url: '/bookshelf/personal-development/' },
      { label: 'Entrepreneurship', url: '/bookshelf/entrepreneurship/' },
      { label: 'Productivity', url: '/bookshelf/productivity/' },
      { label: 'AI & Technology', url: '/bookshelf/ai-technology/' },
      { label: 'Writing & Communication', url: '/bookshelf/writing-communication/' },
    ]
  },
  { label: 'About', url: '/about/', dropdown: [] },
  { label: 'Contact', url: '/contact/', dropdown: [] },
];
---

<nav class="main-nav">
  <div class="nav-container">
    <!-- Logo -->
    <a href="/" class="nav-logo">
      <span class="logo-text">Swahili Hacks</span>
      <span class="logo-tagline">Solutions</span>
    </a>

    <!-- Mobile Toggle -->
    <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <!-- Navigation Links -->
    <ul class="nav-list" id="navList">
      {navItems.map((item) => (
        <li class:list={[
          'nav-item',
          { 'has-dropdown': item.dropdown.length > 0 },
          { 'active': currentPath === item.url }
        ]}>
          <a 
            href={item.url} 
            class="nav-link"
            aria-expanded="false"
          >
            {item.label}
            {item.dropdown.length > 0 && (
              <span class="nav-arrow">▼</span>
            )}
          </a>
          
          {item.dropdown.length > 0 && (
            <ul class="dropdown-menu">
              {item.dropdown.map((sub) => (
                <li>
                  <a href={sub.url} class="dropdown-link">
                    {sub.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .main-nav {
    background: transparent;
    padding: 0.8rem 0;
    position: relative;
    z-index: 9999;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    margin-top: 0.5rem;
  }

  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 20px;
  }

  /* Logo */
  .nav-logo {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
  }

  .logo-text {
    font-size: 1.5rem;
    font-weight: 700;
    color: white;
    letter-spacing: -0.5px;
    transition: color 0.3s ease;
  }

  .logo-text:hover {
    color: #1C75BC;
  }

  .logo-tagline {
    font-size: 0.6rem;
    color: #1C75BC; /* Changed from green to blue */
    letter-spacing: 1px;
    text-transform: uppercase;
    opacity: 0.8;
  }

  /* Navigation List */
  .nav-list {
    display: flex;
    list-style: none;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    align-items: center;
  }

  .nav-item {
    position: relative;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.5rem 1rem;
    color: #94a3b8;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    border-radius: 6px;
    transition: all 0.3s ease;
  }

  .nav-link:hover {
    color: white;
    background: rgba(255, 255, 255, 0.05);
  }

  .nav-item.active .nav-link {
    color: white;
    background: rgba(255, 255, 255, 0.08);
  }

  .nav-arrow {
    font-size: 0.6rem;
    margin-left: 0.15rem;
    transition: transform 0.3s ease;
    color: #1C75BC; /* Changed from green to blue */
  }

  .nav-item:hover .nav-arrow {
    transform: rotate(180deg);
  }

  /* Dropdown Menu */
  .dropdown-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 220px;
    background: #1e293b;
    padding: 0.5rem 0;
    border-radius: 8px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.4);
    list-style: none;
    margin: 0.25rem 0 0 0;
    border: 1px solid rgba(255, 255, 255, 0.05);
    z-index: 99999;
  }

  .nav-item:hover .dropdown-menu {
    display: block;
  }

  .dropdown-link {
    display: block;
    padding: 0.5rem 1.25rem;
    color: #cbd5e1;
    text-decoration: none;
    font-size: 0.85rem;
    transition: all 0.2s ease;
  }

  .dropdown-link:hover {
    background: rgba(28, 117, 188, 0.15);
    color: #1C75BC;
  }

  /* Mobile Toggle */
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
  }

  .nav-toggle span {
    width: 25px;
    height: 2px;
    background: white;
    transition: all 0.3s ease;
  }

  .nav-toggle.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .nav-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .nav-toggle.active span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .main-nav {
      padding: 0.5rem 0;
    }

    .nav-list {
      gap: 0.25rem;
    }

    .nav-link {
      padding: 0.4rem 0.75rem;
      font-size: 0.85rem;
    }
  }

  @media (max-width: 768px) {
    .main-nav {
      padding: 0.4rem 0;
      margin-top: 0.3rem;
    }

    .nav-toggle {
      display: flex;
    }

    .nav-list {
      display: none;
      flex-direction: column;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: #0f172a;
      padding: 1rem;
      gap: 0.5rem;
      border-top: 1px solid rgba(255, 255, 255, 0.05);
      z-index: 99999;
      max-height: 80vh;
      overflow-y: auto;
    }

    .nav-list.open {
      display: flex;
    }

    .nav-item {
      width: 100%;
    }

    .nav-link {
      width: 100%;
      justify-content: space-between;
      padding: 0.75rem 1rem;
    }

    .dropdown-menu {
      position: static;
      background: transparent;
      box-shadow: none;
      padding: 0 0 0 1.5rem;
      border: none;
      margin: 0;
      display: none;
    }

    .nav-item.active .dropdown-menu {
      display: block;
    }

    .nav-item:hover .dropdown-menu {
      display: none;
    }

    .dropdown-link {
      padding: 0.5rem 1rem;
      font-size: 0.9rem;
    }

    .logo-text {
      font-size: 1.2rem;
    }

    .logo-tagline {
      font-size: 0.5rem;
    }
  }

  @media (max-width: 480px) {
    .main-nav {
      padding: 0.3rem 0;
    }

    .nav-link {
      font-size: 0.8rem;
      padding: 0.5rem 0.6rem;
    }

    .dropdown-link {
      font-size: 0.8rem;
      padding: 0.4rem 0.75rem;
    }

    .logo-text {
      font-size: 1rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const toggle = document.getElementById('navToggle');
    const list = document.getElementById('navList');

    if (toggle && list) {
      toggle.addEventListener('click', function() {
        list.classList.toggle('open');
        toggle.classList.toggle('active');
      });

      // Close dropdowns on mobile click
      const navItems = document.querySelectorAll('.nav-item.has-dropdown');
      navItems.forEach(item => {
        const link = item.querySelector('.nav-link');
        if (link) {
          link.addEventListener('click', function(e) {
            if (window.innerWidth <= 768) {
              e.preventDefault();
              const parent = this.closest('.nav-item');
              if (parent) {
                parent.classList.toggle('active');
              }
            }
          });
        }
      });
    }
  });
</script>
