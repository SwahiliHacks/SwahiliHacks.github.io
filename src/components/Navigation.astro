</BaseLayout>

<style>
  /* ===== HERO SECTION ===== */
  .bookshelf-hero {
    padding: 3rem 0;
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    color: white;
    text-align: center;
  }

  .bookshelf-hero h1 {
    font-size: 2.5rem;
    font-weight: 700;
    color: white;
    margin-bottom: 0.5rem;
  }

  .bookshelf-hero p {
    color: #94a3b8;
    font-size: 1.1rem;
  }

  /* ===== FILTER SECTION ===== */
  .filter-section {
    padding: 1.5rem 0;
    background: #f8fafc;
    border-bottom: 1px solid #e2e8f0;
  }

  .filter-bar {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .filter-bar label {
    font-weight: 600;
    color: #0f172a;
    font-size: 0.95rem;
  }

  .filter-select {
    padding: 0.5rem 1.5rem;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    background: white;
    font-size: 0.95rem;
    color: #0f172a;
    cursor: pointer;
    outline: none;
    transition: border-color 0.3s ease;
  }

  .filter-select:focus {
    border-color: #1C75BC;
    box-shadow: 0 0 0 3px rgba(28, 117, 188, 0.1);
  }

  .book-count {
    margin-left: auto;
    color: #64748b;
    font-size: 0.9rem;
  }

  /* ===== BOOKSHELF SECTION ===== */
  .bookshelf-section {
    padding: 4rem 0;
  }

  .bookshelf-section h2 {
    font-size: 2rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 2rem;
  }

  .featured-section {
    background: #f8fafc;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* ===== BOOK GRID ===== */
  .book-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
  }

  .featured-grid {
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  }

  /* ===== BOOK CARD ===== */
  .book-card {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.3s ease;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .book-card:hover {
    border-color: #1C75BC;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.06);
    transform: translateY(-4px);
  }

  .book-card.featured {
    border-color: #f59e0b;
    grid-column: span 1;
  }

  .book-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: #f59e0b;
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    z-index: 1;
  }

  .book-cover {
    height: 200px;
    background: #f8fafc;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    flex-shrink: 0;
  }

  .book-cover img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .book-content {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .book-category {
    display: inline-block;
    padding: 0.15rem 0.6rem;
    background: #eef2ff;
    color: #1C75BC;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    align-self: flex-start;
  }

  .book-content h3 {
    font-size: 1.1rem;
    font-weight: 600;
    color: #0f172a;
    margin-bottom: 0.25rem;
  }

  .book-author {
    font-size: 0.9rem;
    color: #64748b;
    margin-bottom: 0.5rem;
  }

  .book-description {
    font-size: 0.9rem;
    color: #475569;
    margin-bottom: 0.75rem;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .book-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .book-rating {
    color: #f59e0b;
    font-weight: 600;
  }

  .book-reviews {
    font-size: 0.8rem;
    color: #94a3b8;
  }

  .book-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 0.75rem;
    border-top: 1px solid #f1f5f9;
    margin-top: auto;
  }

  .book-price {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1C75BC;
  }

  .btn-sm {
    padding: 0.4rem 1.2rem;
    font-size: 0.85rem;
    white-space: nowrap;
  }

  .btn-primary {
    background: #1C75BC;
    color: white;
    padding: 0.7rem 1.5rem;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    border: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .btn-primary:hover {
    background: #145a8a;
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(28, 117, 188, 0.3);
  }

  .btn-secondary {
    display: inline-block;
    padding: 0.7rem 1.5rem;
    background: transparent;
    color: #1C75BC;
    border: 2px solid #1C75BC;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .btn-secondary:hover {
    background: #1C75BC;
    color: white;
  }

  /* ===== SUGGEST SECTION ===== */
  .suggest-section {
    padding: 4rem 0;
    background: #f8fafc;
  }

  .suggest-content {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }

  .suggest-content h2 {
    font-size: 2rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 0.5rem;
  }

  .suggest-content p {
    color: #64748b;
    font-size: 1.05rem;
    margin-bottom: 2rem;
  }

  .suggest-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .bookshelf-hero h1 {
      font-size: 2rem;
    }

    .book-grid {
      grid-template-columns: 1fr;
    }

    .featured-grid {
      grid-template-columns: 1fr;
    }

    .book-card.featured {
      grid-column: span 1;
    }

    .filter-bar {
      flex-direction: column;
      align-items: stretch;
    }

    .book-count {
      margin-left: 0;
      text-align: center;
    }

    .suggest-actions {
      flex-direction: column;
      align-items: center;
    }

    .btn-secondary {
      width: 100%;
      text-align: center;
    }

    .book-footer {
      flex-direction: column;
      gap: 0.75rem;
      align-items: stretch;
    }

    .book-price {
      text-align: center;
    }

    .btn-sm {
      width: 100%;
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .bookshelf-hero h1 {
      font-size: 1.6rem;
    }

    .bookshelf-hero p {
      font-size: 0.95rem;
    }

    .book-content h3 {
      font-size: 1rem;
    }

    .book-description {
      font-size: 0.85rem;
    }
  }
</style>

<!-- ============================================================
  📊 FILTER JAVASCRIPT
  ============================================================ -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const filterSelect = document.getElementById('category-filter');
    const bookCards = document.querySelectorAll('.book-card');
    const bookCount = document.getElementById('book-count');

    if (filterSelect) {
      filterSelect.addEventListener('change', function() {
        const selectedCategory = this.value;
        let visibleCount = 0;

        bookCards.forEach(card => {
          const cardCategory = card.getAttribute('data-category');
          if (selectedCategory === 'all' || cardCategory === selectedCategory) {
            card.style.display = 'flex';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });

        if (bookCount) {
          bookCount.textContent = visibleCount + ' Books';
        }
      });
    }
  });
</script>
