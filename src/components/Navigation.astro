// Helper function to render stars
function renderStars(rating: number) {
  const fullStars = Math.floor(rating);
  const halfStar = rating % 1 >= 0.5 ? 1 : 0;
  const emptyStars = 5 - fullStars - halfStar;
  let stars = '';
  for (let i = 0; i < fullStars; i++) stars += '⭐';
  if (halfStar) stars += '⭐';
  for (let i = 0; i < emptyStars; i++) stars += '☆';
  return stars;
}
---

<BaseLayout
  title="Bookshelf - Swahili Hacks"
  description="Curated books from trusted sources. Find the best books on trading, productivity, finance, and personal development."
  path="/bookshelf/"
>
  <!-- Bookshelf Hero -->
  <section class="bookshelf-hero">
    <div class="container">
      <h1>Bookshelf</h1>
      <p>Curated books from trusted sources. Every book is handpicked for value and quality.</p>
    </div>
  </section>

  <!-- Category Filter -->
  <section class="filter-section">
    <div class="container">
      <div class="filter-bar">
        <label for="category-filter">Filter by Category:</label>
        <select id="category-filter" class="filter-select">
          {bookCategories.map((cat) => (
            <option value={cat.slug}>{cat.name}</option>
          ))}
        </select>
        <span class="book-count" id="book-count">{books.length} Books</span>
      </div>
    </div>
  </section>

  <!-- Featured Books -->
  <section class="bookshelf-section featured-section">
    <div class="container">
      <h2>Featured Books</h2>
      <div class="book-grid featured-grid">
        {books.filter(b => b.featured).map(book => (
          <div class="book-card featured" data-category={book.category}>
            <div class="book-badge">Featured</div>
            <div class="book-cover">
              <img src={book.cover} alt={book.title} loading="lazy" />
            </div>
            <div class="book-content">
              <span class="book-category">{book.category}</span>
              <h3>{book.title}</h3>
              <p class="book-author">by {book.author}</p>
              <p class="book-description">{book.description}</p>
              <div class="book-meta">
                <span class="book-rating">
                  {renderStars(book.rating)} {book.rating}
                </span>
                <span class="book-reviews">({book.reviews} reviews)</span>
              </div>
              <div class="book-footer">
                <span class="book-price">{book.price}</span>
                <a 
                  href={book.affiliateUrl} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="btn-primary btn-sm"
                  data-affiliate
                  data-product={book.title}
                  data-network="Amazon"
                >
                  View Book <i class="fas fa-arrow-right"></i>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- All Books -->
  <section class="bookshelf-section">
    <div class="container">
      <h2>All Books</h2>
      <div class="book-grid" id="book-grid">
        {books.filter(b => !b.featured).map(book => (
          <div class="book-card" data-category={book.category}>
            <div class="book-cover">
              <img src={book.cover} alt={book.title} loading="lazy" />
            </div>
            <div class="book-content">
              <span class="book-category">{book.category}</span>
              <h3>{book.title}</h3>
              <p class="book-author">by {book.author}</p>
              <p class="book-description">{book.description}</p>
              <div class="book-meta">
